  "sections": [
    {
      "name": "Prematch",
      "fields": [
        {
          "title": "Scouter Initials",
          "description": "Enter the initials of the scouter.",
          "type": "text",
          "required": true,
          "code": "scouter",
          "formResetBehavior": "preserve",
          "defaultValue": ""
        },
        {
          "title": "Match Number",
          "description": "Select the match number.",
          "type": "TBA-match-number",
          "required": true,
          "code": "matchNumber",
          "formResetBehavior": "increment",
          "defaultValue": 1
        },
        {
          "title": "Team and Robot",
          "description": "Select the team and robot position you are scouting.",
          "type": "TBA-team-and-robot",
          "required": true,
          "code": "robot",
          "formResetBehavior": "preserve",
          "defaultValue": null
        },
        {
          "title": "Starting Position",
          "description": "The starting position of the robot.",
          "type": "select",
          "required": true,
          "code": "startPos",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "choices": {
            "Trench": "Trench",
            "Bump": "Bump",
            "Hub": "Hub"
          }
        },
        {
          "title": "No Show",
          "description": "Check if the robot did not show up for the match.",
          "type": "boolean",
          "required": false,
          "code": "noShow",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Autonomous Capabilities",
      "fields": [
        {
          "title": "Did nothing",
          "description": "The robot didn't move in Auto",
          "type": "boolean",
          "required": false,
          "code": "autoNothing",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Preload",
          "description": "Robot shot its preloaded balls",
          "type": "boolean",
          "required": false,
          "code": "autoPreload",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Outpost",
          "description": "Robot got pieces from Outpost (Human Player)",
          "type": "boolean",
          "required": false,
          "code": "autoOutpost",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Depot",
          "description": "Robot got pieces from the Depot",
          "type": "boolean",
          "required": false,
          "code": "autoDepot",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "1st trip to centerline",
          "description": "Robot got pieces from the center once",
          "type": "boolean",
          "required": false,
          "code": "autoCL1",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "2nd trip to centerline",
          "description": "Robot got pieces from the center second time",
          "type": "boolean",
          "required": false,
          "code": "autoCL2",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "3rd trip to centerline",
          "description": "Robot got pieces from the center third time",
          "type": "boolean",
          "required": false,
          "code": "autoCL3",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Teleop",
      "fields": [
        {
          "title": "Scoring Cycles",
          "description": "How many times did the robot score",
          "type": "counter",
          "required": false,
          "code": "fuelCycles",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "step": 1
        },
        {
          "title": "Scoring Accuracy",
          "description": "Rate the robot's scoring effectiveness.",
          "type": "range",
          "required": false,
          "code": "scoringAcc",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 1,
          "max": 4,
          "step": 1
        },
        {
          "title": "Agility",
          "description": "Rate the robot's ability to navigate the field.",
          "type": "range",
          "required": false,
          "code": "agility",
          "formResetBehavior": "reset",
          "defaultValue": 0,
          "min": 1,
          "max": 4,
          "step": 1
        },
        {
          "title": "Incapacitated",
          "description": "Died/Disabled/Broke/Fell over/Beached",
          "type": "select",
          "required": true,
          "code": "broke",
          "formResetBehavior": "reset",
          "defaultValue": "blank",
          "choices": {
            "no": "Robot functioned the whole match",
            "early": "Early in the match",
            "mid": "Middle of match",
            "end": "End of match"
          }
        },
        {
          "title": "Did the robot go over the bump",
          "description": "Was the robot defended by an opponent during the match?",
          "type": "boolean",
          "required": false,
          "code": "bump",
          "formResetBehavior": "reset",
          "defaultValue": false
        }
      ]
    },
    {
      "name": "Postmatch",
      "fields": [
        {
          "title": "Passing",
          "description": "Robot launched pieces to their side",
          "type": "boolean",
          "required": false,
          "code": "passing",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Plowing",
          "description": "Robot plowed pieces to their side",
          "type": "boolean",
          "required": false,
          "code": "plowing",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Defense",
          "description": "Robot played defense",
          "type": "boolean",
          "required": false,
          "code": "defense",
          "formResetBehavior": "reset",
          "defaultValue": false
        },
        {
          "title": "Comments",
          "type": "text",
          "required": false,
          "code": "co",
          "formResetBehavior": "reset",
          "defaultValue": "",
          "min": 0,
          "max": 100
        }
      ]
    }
  ]
}
